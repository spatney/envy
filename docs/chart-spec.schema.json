{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://graphein.dev/chart-spec.schema.json",
  "title": "Graphein ChartSpec",
  "description": "A single JSON-serializable Graphein chart, slicer, or dashboard specification. Discriminated on `type`.",
  "type": "object",
  "required": ["type"],
  "oneOf": [
    { "$ref": "#/$defs/LineSpec" },
    { "$ref": "#/$defs/AreaSpec" },
    { "$ref": "#/$defs/BarSpec" },
    { "$ref": "#/$defs/ScatterSpec" },
    { "$ref": "#/$defs/ComboSpec" },
    { "$ref": "#/$defs/HistogramSpec" },
    { "$ref": "#/$defs/PieSpec" },
    { "$ref": "#/$defs/FunnelSpec" },
    { "$ref": "#/$defs/HeatmapSpec" },
    { "$ref": "#/$defs/KpiSpec" },
    { "$ref": "#/$defs/TreemapSpec" },
    { "$ref": "#/$defs/GaugeSpec" },
    { "$ref": "#/$defs/BulletSpec" },
    { "$ref": "#/$defs/CalendarHeatmapSpec" },
    { "$ref": "#/$defs/WaterfallSpec" },
    { "$ref": "#/$defs/SlopeSpec" },
    { "$ref": "#/$defs/DumbbellSpec" },
    { "$ref": "#/$defs/TableSpec" },
    { "$ref": "#/$defs/MatrixSpec" },
    { "$ref": "#/$defs/BoxSpec" },
    { "$ref": "#/$defs/SankeySpec" },
    { "$ref": "#/$defs/ChoroplethSpec" },
    { "$ref": "#/$defs/DropdownSlicerSpec" },
    { "$ref": "#/$defs/SearchSlicerSpec" },
    { "$ref": "#/$defs/ListSlicerSpec" },
    { "$ref": "#/$defs/RangeSlicerSpec" },
    { "$ref": "#/$defs/DateRangeSlicerSpec" },
    { "$ref": "#/$defs/DashboardSpec" }
  ],
  "$defs": {
    "FieldType": {
      "type": "string",
      "enum": ["quantitative", "temporal", "ordinal", "nominal"]
    },
    "AggOp": {
      "type": "string",
      "enum": ["sum", "mean", "avg", "min", "max", "count", "countDistinct", "median", "first", "last"]
    },
    "Transform": {
      "description": "A single declarative data transform step. Carries exactly one operator key.",
      "oneOf": [
        { "$ref": "#/$defs/AggregateTransform" },
        { "$ref": "#/$defs/BinTransform" },
        { "$ref": "#/$defs/FilterTransform" },
        { "$ref": "#/$defs/FoldTransform" },
        { "$ref": "#/$defs/TimeUnitTransform" },
        { "$ref": "#/$defs/CalculateTransform" }
      ]
    },
    "AggregateOp": {
      "type": "object",
      "properties": {
        "op": { "$ref": "#/$defs/AggOp" },
        "field": { "type": "string", "description": "Source column (omit only for count)." },
        "as": { "type": "string", "description": "Output column for the aggregated value." }
      },
      "required": ["op", "as"],
      "additionalProperties": false
    },
    "AggregateTransform": {
      "type": "object",
      "properties": {
        "aggregate": { "type": "array", "items": { "$ref": "#/$defs/AggregateOp" }, "minItems": 1 },
        "groupby": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["aggregate"],
      "additionalProperties": false
    },
    "BinTransform": {
      "type": "object",
      "properties": {
        "bin": { "type": "string", "description": "Numeric column to bin." },
        "as": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" }, "minItems": 2, "maxItems": 2 }
          ],
          "description": "Bin start column, or a [start, end] pair."
        },
        "maxbins": { "type": "number" },
        "step": { "type": "number" },
        "extent": { "type": "array", "items": { "type": "number" }, "minItems": 2, "maxItems": 2 },
        "nice": { "type": "boolean" }
      },
      "required": ["bin", "as"],
      "additionalProperties": false
    },
    "FilterTransform": {
      "type": "object",
      "properties": { "filter": { "$ref": "#/$defs/FilterPredicate" } },
      "required": ["filter"],
      "additionalProperties": false
    },
    "FilterPredicate": {
      "description": "A JSON predicate: a leaf comparison on one field, or and/or/not composition.",
      "type": "object",
      "properties": {
        "field": { "type": "string" },
        "equals": {},
        "ne": {},
        "oneOf": { "type": "array" },
        "range": { "type": "array", "minItems": 2, "maxItems": 2 },
        "contains": { "type": "string" },
        "gt": { "type": ["number", "string"] },
        "gte": { "type": ["number", "string"] },
        "lt": { "type": ["number", "string"] },
        "lte": { "type": ["number", "string"] },
        "valid": { "type": "boolean" },
        "and": { "type": "array", "items": { "$ref": "#/$defs/FilterPredicate" } },
        "or": { "type": "array", "items": { "$ref": "#/$defs/FilterPredicate" } },
        "not": { "$ref": "#/$defs/FilterPredicate" }
      }
    },
    "FoldTransform": {
      "type": "object",
      "properties": {
        "fold": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "as": { "type": "array", "items": { "type": "string" }, "minItems": 2, "maxItems": 2 }
      },
      "required": ["fold"],
      "additionalProperties": false
    },
    "TimeUnit": {
      "type": "string",
      "enum": ["year", "quarter", "month", "week", "day", "hour", "minute", "second"]
    },
    "TimeUnitTransform": {
      "type": "object",
      "properties": {
        "timeUnit": { "$ref": "#/$defs/TimeUnit" },
        "field": { "type": "string" },
        "as": { "type": "string" }
      },
      "required": ["timeUnit", "field", "as"],
      "additionalProperties": false
    },
    "CalculateTransform": {
      "type": "object",
      "description": "Derive a column from a safe, JSON-string expression (arithmetic, comparison, logical, ternary, string concat, member access, and a function whitelist). No eval/Function.",
      "properties": {
        "calculate": { "type": "string", "description": "Expression evaluated per row. Bare identifiers reference columns; use datum['my field'] for awkward names." },
        "as": { "type": "string", "description": "Output column for the result." }
      },
      "required": ["calculate", "as"],
      "additionalProperties": false
    },
    "CurveType": {
      "type": "string",
      "enum": ["linear", "monotone", "step", "stepBefore", "stepAfter", "catmullRom"]
    },
    "Annotation": {
      "type": "object",
      "description": "A reference line, band, or threshold zone overlaid on a cartesian plot.",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["line", "band", "zone"],
          "description": "Omit to infer: a line when value is set, a band when from/to are set. zone is a band alias."
        },
        "axis": {
          "type": "string",
          "enum": ["x", "y"],
          "description": "Axis the value(s) are measured against. y (default) is horizontal; x is vertical."
        },
        "value": {
          "oneOf": [{ "type": "number" }, { "type": "string" }],
          "description": "Reference value for a line."
        },
        "from": { "oneOf": [{ "type": "number" }, { "type": "string" }], "description": "Start of a band/zone." },
        "to": { "oneOf": [{ "type": "number" }, { "type": "string" }], "description": "End of a band/zone." },
        "label": { "type": "string" },
        "color": { "type": "string" },
        "strokeWidth": { "type": "number" },
        "strokeDash": { "type": "array", "items": { "type": "number" } },
        "fillOpacity": { "type": "number", "minimum": 0, "maximum": 1 },
        "labelPosition": { "type": "string", "enum": ["start", "middle", "end"] }
      },
      "additionalProperties": false
    },
    "Datum": {
      "type": "object",
      "additionalProperties": true
    },
    "ScaleConfig": {
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["linear", "log", "time", "band", "point"] },
        "domain": {
          "oneOf": [
            { "type": "array", "items": { "type": "number" }, "minItems": 2, "maxItems": 2 },
            { "type": "array", "items": { "type": "string" } }
          ]
        },
        "nice": { "type": "boolean" },
        "zero": { "type": "boolean" },
        "clamp": { "type": "boolean" },
        "padding": { "type": "number", "minimum": 0, "maximum": 1 },
        "base": { "type": "number" },
        "reverse": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "FieldDef": {
      "type": "object",
      "required": ["field"],
      "properties": {
        "field": { "type": "string" },
        "type": { "$ref": "#/$defs/FieldType" },
        "aggregate": { "$ref": "#/$defs/AggOp" },
        "title": { "type": "string" },
        "format": { "type": "string" },
        "scale": { "$ref": "#/$defs/ScaleConfig" }
      },
      "additionalProperties": false
    },
    "Encoding": {
      "type": "object",
      "properties": {
        "x": { "$ref": "#/$defs/FieldDef" },
        "y": { "$ref": "#/$defs/FieldDef" },
        "y2": { "$ref": "#/$defs/FieldDef" },
        "color": { "$ref": "#/$defs/FieldDef" },
        "size": { "$ref": "#/$defs/FieldDef" },
        "series": { "$ref": "#/$defs/FieldDef" },
        "theta": { "$ref": "#/$defs/FieldDef" },
        "stage": { "$ref": "#/$defs/FieldDef" },
        "source": { "$ref": "#/$defs/FieldDef" },
        "target": { "$ref": "#/$defs/FieldDef" },
        "value": { "$ref": "#/$defs/FieldDef" },
        "key": { "$ref": "#/$defs/FieldDef" },
        "label": { "$ref": "#/$defs/FieldDef" }
      },
      "additionalProperties": false
    },
    "Dimensions": {
      "type": "object",
      "properties": {
        "width": { "type": "number" },
        "height": { "type": "number" },
        "autoResize": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "AxisConfig": {
      "type": "object",
      "properties": {
        "show": { "type": "boolean" },
        "title": { "type": "string" },
        "grid": { "type": "boolean" },
        "ticks": { "type": "number" },
        "tickValues": { "type": "array", "items": { "type": "number" } },
        "format": { "type": "string" },
        "labels": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "AxesConfig": {
      "type": "object",
      "properties": {
        "x": { "$ref": "#/$defs/AxisConfig" },
        "y": { "$ref": "#/$defs/AxisConfig" }
      },
      "additionalProperties": false
    },
    "LegendConfig": {
      "oneOf": [
        { "type": "boolean" },
        {
          "type": "object",
          "properties": {
            "show": { "type": "boolean" },
            "position": { "type": "string", "enum": ["top", "right", "bottom", "left"] },
            "title": { "type": "string" }
          },
          "additionalProperties": false
        }
      ]
    },
    "TooltipConfig": {
      "oneOf": [
        { "type": "boolean" },
        {
          "type": "object",
          "properties": { "show": { "type": "boolean" } },
          "additionalProperties": false
        }
      ]
    },
    "TitleConfig": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "properties": {
            "text": { "type": "string" },
            "subtitle": { "type": "string" },
            "align": { "type": "string", "enum": ["left", "center", "right"] }
          },
          "additionalProperties": false
        }
      ]
    },
    "AnimationConfig": {
      "oneOf": [
        { "type": "boolean" },
        {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "duration": { "type": "number" },
            "easing": { "type": "string" }
          },
          "additionalProperties": false
        }
      ]
    },
    "SketchConfig": {
      "description": "Hand-drawn (rough.js-style) rendering. `true` uses all defaults.",
      "oneOf": [
        { "type": "boolean" },
        {
          "type": "object",
          "properties": {
            "roughness": { "type": "number", "minimum": 0 },
            "bowing": { "type": "number", "minimum": 0 },
            "fillStyle": { "type": "string", "enum": ["hachure", "solid", "cross-hatch"] },
            "hachureGap": { "type": "number", "minimum": 0 },
            "hachureAngle": { "type": "number" },
            "strokeWidth": { "type": "number", "minimum": 0 },
            "seed": { "type": "number" },
            "font": { "type": "boolean" }
          },
          "additionalProperties": false
        }
      ]
    },
    "Insets": {
      "type": "object",
      "properties": {
        "top": { "type": "number" },
        "right": { "type": "number" },
        "bottom": { "type": "number" },
        "left": { "type": "number" }
      },
      "additionalProperties": false
    },
    "ThemeInput": {
      "oneOf": [
        { "type": "string", "enum": ["light", "dark"] },
        { "type": "object", "additionalProperties": true }
      ]
    },
    "ValueRef": {
      "oneOf": [
        { "type": "number" },
        {
          "type": "object",
          "required": ["field"],
          "properties": {
            "field": { "type": "string" },
            "aggregate": { "$ref": "#/$defs/AggOp" }
          },
          "additionalProperties": false
        }
      ]
    },
    "ConditionalFormat": {
      "oneOf": [
        {
          "type": "object",
          "required": ["type"],
          "properties": {
            "type": { "const": "colorScale" },
            "scheme": { "type": "string" },
            "domain": { "type": "array", "items": { "type": "number" }, "minItems": 2, "maxItems": 2 },
            "midpoint": { "type": "number" },
            "diverging": { "type": "boolean" },
            "target": { "type": "string", "enum": ["background", "text"] }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type"],
          "properties": {
            "type": { "const": "bar" },
            "color": { "type": "string" },
            "negativeColor": { "type": "string" },
            "domain": { "type": "array", "items": { "type": "number" }, "minItems": 2, "maxItems": 2 },
            "baseline": { "type": "string", "enum": ["zero", "min"] },
            "showValue": { "type": "boolean" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type"],
          "properties": {
            "type": { "const": "icon" },
            "set": { "type": "string", "enum": ["arrows", "triangles", "dots", "trafficLights"] },
            "rules": { "type": "array", "items": { "$ref": "#/$defs/IconRule" } },
            "position": { "type": "string", "enum": ["left", "right"] }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "rules"],
          "properties": {
            "type": { "const": "rules" },
            "rules": { "type": "array", "items": { "$ref": "#/$defs/ValueRule" }, "minItems": 1 }
          },
          "additionalProperties": false
        }
      ]
    },
    "ValueRule": {
      "type": "object",
      "required": ["when", "value"],
      "properties": {
        "when": { "type": "string", "enum": ["gt", "gte", "lt", "lte", "eq", "ne", "between"] },
        "value": { "type": ["number", "string"] },
        "to": { "type": "number" },
        "background": { "type": "string" },
        "color": { "type": "string" },
        "weight": { "type": "string", "enum": ["bold", "normal"] },
        "icon": { "type": "string" }
      },
      "additionalProperties": false
    },
    "IconRule": {
      "type": "object",
      "required": ["when", "value"],
      "properties": {
        "when": { "type": "string", "enum": ["gt", "gte", "lt", "lte", "eq", "ne", "between"] },
        "value": { "type": "number" },
        "to": { "type": "number" },
        "icon": { "type": "string" },
        "color": { "type": "string" }
      },
      "additionalProperties": false
    },
    "TableColumn": {
      "type": "object",
      "required": ["field"],
      "properties": {
        "field": { "type": "string" },
        "title": { "type": "string" },
        "type": { "$ref": "#/$defs/FieldType" },
        "format": { "type": "string" },
        "align": { "type": "string", "enum": ["left", "center", "right"] },
        "width": { "type": "number" },
        "conditionalFormat": { "$ref": "#/$defs/ConditionalFormat" },
        "prefix": { "type": "string" },
        "suffix": { "type": "string" },
        "negativeStyle": { "type": "string", "enum": ["sign", "parens", "red", "parens-red"] },
        "hidden": { "type": "boolean" },
        "sortable": { "type": "boolean" },
        "wrap": { "type": "boolean" },
        "group": { "type": "string" },
        "total": { "oneOf": [{ "$ref": "#/$defs/AggOp" }, { "const": false }] }
      },
      "additionalProperties": false
    },
    "MatrixValueDef": {
      "type": "object",
      "required": ["field", "op"],
      "properties": {
        "field": { "type": "string" },
        "op": { "$ref": "#/$defs/AggOp" },
        "label": { "type": "string" },
        "format": { "type": "string" },
        "conditionalFormat": { "$ref": "#/$defs/ConditionalFormat" },
        "prefix": { "type": "string" },
        "suffix": { "type": "string" },
        "negativeStyle": { "type": "string", "enum": ["sign", "parens", "red", "parens-red"] },
        "showAs": { "type": "string", "enum": ["value", "percentOfRow", "percentOfColumn", "percentOfTotal"] }
      },
      "additionalProperties": false
    },
    "BaseProps": {
      "type": "object",
      "properties": {
        "data": { "type": "array", "items": { "$ref": "#/$defs/Datum" } },
        "transform": { "type": "array", "items": { "$ref": "#/$defs/Transform" } },
        "theme": { "$ref": "#/$defs/ThemeInput" },
        "dimensions": { "$ref": "#/$defs/Dimensions" },
        "title": { "$ref": "#/$defs/TitleConfig" },
        "description": { "type": "string" },
        "legend": { "$ref": "#/$defs/LegendConfig" },
        "tooltip": { "$ref": "#/$defs/TooltipConfig" },
        "axes": { "$ref": "#/$defs/AxesConfig" },
        "animation": { "$ref": "#/$defs/AnimationConfig" },
        "padding": { "$ref": "#/$defs/Insets" },
        "background": { "type": "string" },
        "sketch": { "$ref": "#/$defs/SketchConfig" },
        "params": { "type": "array", "items": { "$ref": "#/$defs/SelectionParam" } },
        "highlight": {
          "oneOf": [
            { "$ref": "#/$defs/HighlightConfig" },
            { "type": "array", "items": { "$ref": "#/$defs/HighlightConfig" } }
          ]
        },
        "filter": { "type": "array", "items": { "$ref": "#/$defs/FilterClause" } }
      }
    },
    "LineSpec": {
      "allOf": [{ "$ref": "#/$defs/BaseProps" }],
      "type": "object",
      "required": ["type", "encoding"],
      "properties": {
        "type": { "const": "line" },
        "encoding": {
          "allOf": [{ "$ref": "#/$defs/Encoding" }],
          "required": ["x", "y"]
        },
        "curve": { "$ref": "#/$defs/CurveType" },
        "points": { "type": "boolean" },
        "area": { "type": "boolean" },
        "annotations": { "type": "array", "items": { "$ref": "#/$defs/Annotation" } }
      }
    },
    "AreaSpec": {
      "allOf": [{ "$ref": "#/$defs/BaseProps" }],
      "type": "object",
      "required": ["type", "encoding"],
      "properties": {
        "type": { "const": "area" },
        "encoding": {
          "allOf": [{ "$ref": "#/$defs/Encoding" }],
          "required": ["x", "y"]
        },
        "curve": { "$ref": "#/$defs/CurveType" },
        "stack": { "type": "boolean" },
        "annotations": { "type": "array", "items": { "$ref": "#/$defs/Annotation" } }
      }
    },
    "BarSpec": {
      "allOf": [{ "$ref": "#/$defs/BaseProps" }],
      "type": "object",
      "required": ["type", "encoding"],
      "properties": {
        "type": { "const": "bar" },
        "encoding": {
          "allOf": [{ "$ref": "#/$defs/Encoding" }],
          "required": ["x", "y"]
        },
        "orientation": { "type": "string", "enum": ["vertical", "horizontal"] },
        "stack": { "type": "boolean" },
        "group": { "type": "boolean" },
        "cornerRadius": { "type": "number" },
        "annotations": { "type": "array", "items": { "$ref": "#/$defs/Annotation" } }
      }
    },
    "ScatterSpec": {
      "allOf": [{ "$ref": "#/$defs/BaseProps" }],
      "type": "object",
      "required": ["type", "encoding"],
      "properties": {
        "type": { "const": "scatter" },
        "encoding": {
          "allOf": [{ "$ref": "#/$defs/Encoding" }],
          "required": ["x", "y"]
        },
        "annotations": { "type": "array", "items": { "$ref": "#/$defs/Annotation" } }
      }
    },
    "ComboMark": { "enum": ["line", "bar", "area", "scatter"] },
    "ComboLayer": {
      "type": "object",
      "required": ["mark", "encoding"],
      "properties": {
        "mark": { "$ref": "#/$defs/ComboMark" },
        "encoding": {
          "type": "object",
          "required": ["y"],
          "properties": { "y": { "$ref": "#/$defs/FieldDef" } }
        },
        "axis": { "enum": ["left", "right"], "description": "Which y-axis this layer is measured against (default left)." },
        "curve": { "$ref": "#/$defs/CurveType" },
        "points": { "type": "boolean" },
        "area": { "type": "boolean", "description": "Fill under a line layer." },
        "cornerRadius": { "type": "number", "minimum": 0 },
        "name": { "type": "string", "description": "Legend label (defaults to the y field)." },
        "color": { "type": "string" }
      }
    },
    "ComboSpec": {
      "allOf": [{ "$ref": "#/$defs/BaseProps" }],
      "type": "object",
      "required": ["type", "encoding", "layers"],
      "properties": {
        "type": { "const": "combo" },
        "encoding": {
          "type": "object",
          "required": ["x"],
          "properties": { "x": { "$ref": "#/$defs/FieldDef" } }
        },
        "layers": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/ComboLayer" } }
      }
    },
    "HistogramBin": {
      "type": "object",
      "properties": {
        "maxbins": { "type": "number", "minimum": 1, "description": "Target bin count (approximate; default 10)." },
        "step": { "type": "number", "exclusiveMinimum": 0, "description": "Explicit bin width (overrides maxbins)." },
        "extent": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 2,
          "maxItems": 2,
          "description": "Restrict binning to [min, max]; values outside are dropped."
        },
        "nice": { "type": "boolean", "description": "Snap bin edges to nice round numbers (default true)." }
      }
    },
    "HistogramSpec": {
      "allOf": [{ "$ref": "#/$defs/BaseProps" }],
      "type": "object",
      "required": ["type", "encoding"],
      "properties": {
        "type": { "const": "histogram" },
        "encoding": {
          "type": "object",
          "required": ["x"],
          "properties": { "x": { "$ref": "#/$defs/FieldDef" } },
          "description": "`x` is the quantitative field to bin."
        },
        "bin": { "$ref": "#/$defs/HistogramBin" },
        "density": { "type": "boolean", "description": "Normalize bar heights to a probability density (area sums to 1)." },
        "color": { "type": "string" },
        "cornerRadius": { "type": "number", "minimum": 0 }
      }
    },
    "PieSpec": {
      "allOf": [{ "$ref": "#/$defs/BaseProps" }],
      "type": "object",
      "required": ["type", "encoding"],
      "properties": {
        "type": { "const": "pie" },
        "encoding": {
          "allOf": [{ "$ref": "#/$defs/Encoding" }],
          "required": ["theta", "color"]
        },
        "donut": { "oneOf": [{ "type": "boolean" }, { "type": "number", "minimum": 0, "maximum": 1 }] },
        "labels": { "oneOf": [{ "type": "boolean" }, { "$ref": "#/$defs/PieLabels" }] }
      }
    },
    "PieLabels": {
      "type": "object",
      "properties": {
        "show": { "type": "boolean" },
        "placement": { "enum": ["inside", "outside", "auto"] },
        "content": { "enum": ["percent", "value", "category", "category-percent", "category-value"] },
        "minShare": { "type": "number", "minimum": 0, "maximum": 1 },
        "connector": { "enum": ["slice", "muted"] }
      },
      "additionalProperties": false
    },
    "FunnelSpec": {
      "allOf": [{ "$ref": "#/$defs/BaseProps" }],
      "type": "object",
      "required": ["type", "encoding"],
      "properties": {
        "type": { "const": "funnel" },
        "encoding": {
          "allOf": [{ "$ref": "#/$defs/Encoding" }],
          "required": ["stage", "value"]
        },
        "labels": { "type": "boolean" },
        "percent": { "enum": ["first", "previous"] }
      }
    },
    "HeatmapSpec": {
      "allOf": [{ "$ref": "#/$defs/BaseProps" }],
      "type": "object",
      "required": ["type", "encoding"],
      "properties": {
        "type": { "const": "heatmap" },
        "encoding": {
          "allOf": [{ "$ref": "#/$defs/Encoding" }],
          "required": ["x", "y", "color"]
        },
        "scheme": { "type": "string" }
      }
    },
    "KpiSpec": {
      "allOf": [{ "$ref": "#/$defs/BaseProps" }],
      "type": "object",
      "required": ["type", "value"],
      "properties": {
        "type": { "const": "kpi" },
        "value": { "$ref": "#/$defs/ValueRef" },
        "label": { "type": "string" },
        "delta": { "$ref": "#/$defs/ValueRef" },
        "format": { "type": "string" },
        "sparkline": {
          "oneOf": [
            { "type": "boolean" },
            {
              "type": "object",
              "required": ["field"],
              "properties": { "field": { "type": "string" } },
              "additionalProperties": false
            }
          ]
        }
      }
    },
    "TreemapSpec": {
      "allOf": [{ "$ref": "#/$defs/BaseProps" }],
      "type": "object",
      "required": ["type", "encoding"],
      "properties": {
        "type": { "const": "treemap" },
        "encoding": {
          "allOf": [{ "$ref": "#/$defs/Encoding" }],
          "required": ["category", "value"],
          "description": "`category` labels each leaf tile, `value` sizes its area; optional `group` nests leaves under parent tiles and `color` overrides the fill."
        },
        "scheme": { "type": "string", "description": "Sequential color scheme when `color` is numeric (default 'teal')." },
        "labels": { "type": "boolean", "description": "Show the value beneath the label inside each tile (default true)." }
      }
    },
    "GaugeSpec": {
      "allOf": [{ "$ref": "#/$defs/BaseProps" }],
      "type": "object",
      "required": ["type", "value", "max"],
      "properties": {
        "type": { "const": "gauge" },
        "value": { "$ref": "#/$defs/ValueRef" },
        "min": { "type": "number", "description": "Scale start (default 0)." },
        "max": { "type": "number", "description": "Scale end — the gauge's full-scale." },
        "target": { "$ref": "#/$defs/ValueRef" },
        "label": { "type": "string" },
        "format": { "type": "string" },
        "bands": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["to"],
            "properties": {
              "to": { "type": "number", "description": "Upper bound of this qualitative band on the scale." },
              "color": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      }
    },
    "BulletSpec": {
      "allOf": [{ "$ref": "#/$defs/BaseProps" }],
      "type": "object",
      "required": ["type", "value"],
      "properties": {
        "type": { "const": "bullet" },
        "value": { "$ref": "#/$defs/ValueRef" },
        "target": { "$ref": "#/$defs/ValueRef" },
        "min": { "type": "number", "description": "Scale start (default 0)." },
        "max": { "type": "number", "description": "Scale end (default derived from value/target/ranges)." },
        "ranges": {
          "type": "array",
          "items": { "type": "number" },
          "description": "Ascending qualitative range boundaries (e.g. [50, 75, 100])."
        },
        "label": { "type": "string" },
        "format": { "type": "string" }
      }
    },
    "CalendarHeatmapSpec": {
      "allOf": [{ "$ref": "#/$defs/BaseProps" }],
      "type": "object",
      "required": ["type", "encoding"],
      "properties": {
        "type": { "const": "calendarHeatmap" },
        "encoding": {
          "allOf": [{ "$ref": "#/$defs/Encoding" }],
          "required": ["date", "color"],
          "description": "`date` is the day (Date or ISO string), `color` the numeric value coloring each cell."
        },
        "scheme": { "type": "string", "description": "Sequential color scheme for the value scale (default 'teal')." }
      }
    },
    "WaterfallSpec": {
      "allOf": [{ "$ref": "#/$defs/BaseProps" }],
      "type": "object",
      "required": ["type", "encoding"],
      "properties": {
        "type": { "const": "waterfall" },
        "encoding": {
          "allOf": [{ "$ref": "#/$defs/Encoding" }],
          "required": ["stage", "value"],
          "description": "`stage` labels each bar (x-axis, data order); `value` is the SIGNED change at that stage (positive rises, negative falls)."
        },
        "totals": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Stage labels to draw as absolute running-total bars from the baseline."
        },
        "showTotal": { "type": "boolean", "description": "Append a final bar summing every step (default false)." },
        "totalLabel": { "type": "string", "description": "Label for the appended total bar (default 'Total')." },
        "labels": { "type": "boolean", "description": "Per-bar value labels (default true)." },
        "cornerRadius": { "type": "number", "minimum": 0, "description": "Bar corner radius in pixels (default 2)." },
        "increaseColor": { "type": "string", "description": "Color for upward steps (default theme positive/green)." },
        "decreaseColor": { "type": "string", "description": "Color for downward steps (default theme negative/red)." },
        "totalColor": { "type": "string", "description": "Color for total/subtotal bars (default theme accent)." }
      }
    },
    "SlopeSpec": {
      "allOf": [{ "$ref": "#/$defs/BaseProps" }],
      "type": "object",
      "required": ["type", "encoding"],
      "properties": {
        "type": { "const": "slope" },
        "encoding": {
          "allOf": [{ "$ref": "#/$defs/Encoding" }],
          "required": ["x", "y", "series"],
          "description": "`x` is the ordinal position (typically two: start/end), `y` the value, `series` the entity drawn as one line."
        },
        "labels": { "type": "boolean", "description": "Direct end labels (series name + value) at each line's ends (default true)." },
        "colorByChange": { "type": "boolean", "description": "Color each line green/red by its net rise/fall instead of by series." },
        "format": { "type": "string", "description": "Number format for value labels and the y-axis." }
      }
    },
    "DumbbellSpec": {
      "allOf": [{ "$ref": "#/$defs/BaseProps" }],
      "type": "object",
      "required": ["type", "encoding"],
      "properties": {
        "type": { "const": "dumbbell" },
        "encoding": {
          "allOf": [{ "$ref": "#/$defs/Encoding" }],
          "required": ["category", "value", "group"],
          "description": "`category` is one row down the y-axis, `value` the dot position on the horizontal axis, `group` the dot identity (2+ → one dot each, connected)."
        },
        "labels": { "type": "boolean", "description": "Value labels beside the dots (default false)." },
        "format": { "type": "string", "description": "Number format for value labels and the x-axis." },
        "sort": { "type": "string", "enum": ["ascending", "descending", "gap"], "description": "Order the category rows (default: data order). 'gap' sorts by dot spread." }
      }
    },
    "TableSpec": {
      "allOf": [{ "$ref": "#/$defs/BaseProps" }],
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "const": "table" },
        "columns": { "type": "array", "items": { "$ref": "#/$defs/TableColumn" } },
        "sort": {
          "type": "object",
          "required": ["field"],
          "properties": {
            "field": { "type": "string" },
            "order": { "type": "string", "enum": ["asc", "desc"] }
          },
          "additionalProperties": false
        },
        "density": { "type": "string", "enum": ["comfortable", "standard", "compact"] },
        "totals": {
          "oneOf": [
            { "type": "boolean" },
            {
              "type": "object",
              "properties": { "label": { "type": "string" } },
              "additionalProperties": false
            }
          ]
        },
        "striped": { "type": "boolean" },
        "stickyHeader": { "type": "boolean" }
      }
    },
    "MatrixSpec": {
      "allOf": [{ "$ref": "#/$defs/BaseProps" }],
      "type": "object",
      "required": ["type", "rows", "values"],
      "properties": {
        "type": { "const": "matrix" },
        "rows": { "type": "array", "items": { "type": "string" } },
        "columns": { "type": "array", "items": { "type": "string" } },
        "values": { "type": "array", "items": { "$ref": "#/$defs/MatrixValueDef" }, "minItems": 1 },
        "subtotals": { "type": "boolean" },
        "grandTotals": { "type": "boolean" },
        "density": { "type": "string", "enum": ["comfortable", "standard", "compact"] },
        "columnSort": {
          "type": "object",
          "required": ["by"],
          "properties": {
            "by": { "type": "string", "enum": ["value", "label"] },
            "valueIndex": { "type": "integer", "minimum": 0 },
            "order": { "type": "string", "enum": ["asc", "desc"] }
          },
          "additionalProperties": false
        }
      }
    },
    "BoxSpec": {
      "allOf": [{ "$ref": "#/$defs/BaseProps" }],
      "type": "object",
      "required": ["type", "encoding"],
      "properties": {
        "type": { "const": "box" },
        "encoding": {
          "allOf": [{ "$ref": "#/$defs/Encoding" }],
          "required": ["x", "y"]
        },
        "whisker": { "type": "string", "enum": ["tukey", "minMax"] },
        "outliers": { "type": "boolean" },
        "annotations": { "type": "array", "items": { "$ref": "#/$defs/Annotation" } }
      }
    },
    "SankeySpec": {
      "allOf": [{ "$ref": "#/$defs/BaseProps" }],
      "type": "object",
      "required": ["type", "encoding"],
      "properties": {
        "type": { "const": "sankey" },
        "encoding": {
          "allOf": [{ "$ref": "#/$defs/Encoding" }],
          "required": ["source", "target", "value"]
        },
        "nodeWidth": { "type": "number" },
        "nodePadding": { "type": "number" },
        "nodeValues": { "type": "boolean" }
      }
    },
    "ChoroplethSpec": {
      "allOf": [{ "$ref": "#/$defs/BaseProps" }],
      "type": "object",
      "required": ["type", "geo", "encoding"],
      "properties": {
        "type": { "const": "choropleth" },
        "geo": { "$ref": "#/$defs/GeoFeatureCollection" },
        "encoding": {
          "allOf": [{ "$ref": "#/$defs/Encoding" }],
          "required": ["key", "color"]
        },
        "featureId": { "type": "string" },
        "projection": { "type": "string", "enum": ["mercator", "equirectangular", "identity"] },
        "scheme": { "type": "string" }
      }
    },
    "GeoFeatureCollection": {
      "type": "object",
      "required": ["type", "features"],
      "properties": {
        "type": { "const": "FeatureCollection" },
        "features": { "type": "array", "items": { "$ref": "#/$defs/GeoFeature" } }
      },
      "additionalProperties": true
    },
    "GeoFeature": {
      "type": "object",
      "required": ["type", "geometry"],
      "properties": {
        "type": { "const": "Feature" },
        "id": { "oneOf": [{ "type": "string" }, { "type": "number" }] },
        "properties": { "type": ["object", "null"] },
        "geometry": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "required": ["type", "coordinates"],
              "properties": {
                "type": { "type": "string", "enum": ["Polygon", "MultiPolygon"] },
                "coordinates": { "type": "array" }
              },
              "additionalProperties": true
            }
          ]
        }
      },
      "additionalProperties": true
    },
    "SelectionDef": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "enum": ["point", "interval"] },
        "on": { "type": "string", "enum": ["click", "hover"] },
        "fields": { "type": "array", "items": { "type": "string" } },
        "toggle": { "type": "boolean" },
        "empty": { "type": "string", "enum": ["all", "none"] }
      },
      "additionalProperties": false
    },
    "SelectionParam": {
      "type": "object",
      "required": ["name", "select"],
      "properties": {
        "name": { "type": "string" },
        "select": { "$ref": "#/$defs/SelectionDef" },
        "value": { "$ref": "#/$defs/SelectionValue" }
      },
      "additionalProperties": false
    },
    "SelectionValue": {
      "oneOf": [
        {
          "type": "object",
          "required": ["kind", "fields", "tuples"],
          "properties": {
            "kind": { "const": "point" },
            "fields": { "type": "array", "items": { "type": "string" } },
            "tuples": { "type": "array", "items": { "type": "array" } }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["kind", "field", "values"],
          "properties": {
            "kind": { "const": "set" },
            "field": { "type": "string" },
            "values": { "type": "array" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["kind", "field"],
          "properties": {
            "kind": { "const": "range" },
            "field": { "type": "string" },
            "min": { "type": ["number", "string"] },
            "max": { "type": ["number", "string"] }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["kind", "field", "query"],
          "properties": {
            "kind": { "const": "text" },
            "field": { "type": "string" },
            "query": { "type": "string" }
          },
          "additionalProperties": false
        }
      ]
    },
    "HighlightConfig": {
      "type": "object",
      "required": ["param"],
      "properties": { "param": { "type": "string" } },
      "additionalProperties": false
    },
    "LiteralPredicate": {
      "oneOf": [
        {
          "type": "object",
          "required": ["field", "equals"],
          "properties": { "field": { "type": "string" }, "equals": {} },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["field", "oneOf"],
          "properties": { "field": { "type": "string" }, "oneOf": { "type": "array" } },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["field", "range"],
          "properties": {
            "field": { "type": "string" },
            "range": { "type": "array", "items": { "type": ["number", "string"] }, "minItems": 2, "maxItems": 2 }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["field", "contains"],
          "properties": { "field": { "type": "string" }, "contains": { "type": "string" } },
          "additionalProperties": false
        }
      ]
    },
    "FilterClause": {
      "oneOf": [
        {
          "type": "object",
          "required": ["param"],
          "properties": { "param": { "type": "string" } },
          "additionalProperties": false
        },
        { "$ref": "#/$defs/LiteralPredicate" }
      ]
    },
    "BaseSlicerProps": {
      "allOf": [{ "$ref": "#/$defs/BaseProps" }],
      "type": "object",
      "required": ["field"],
      "properties": {
        "field": { "type": "string" },
        "param": { "type": "string" },
        "label": { "type": "string" },
        "as": { "type": "string", "enum": ["filter", "highlight"] }
      }
    },
    "DropdownSlicerSpec": {
      "allOf": [{ "$ref": "#/$defs/BaseSlicerProps" }],
      "type": "object",
      "required": ["type", "field"],
      "properties": {
        "type": { "const": "dropdown" },
        "multiple": { "type": "boolean" },
        "placeholder": { "type": "string" }
      }
    },
    "SearchSlicerSpec": {
      "allOf": [{ "$ref": "#/$defs/BaseSlicerProps" }],
      "type": "object",
      "required": ["type", "field"],
      "properties": {
        "type": { "const": "search" },
        "placeholder": { "type": "string" },
        "debounce": { "type": "number", "minimum": 0 }
      }
    },
    "ListSlicerSpec": {
      "allOf": [{ "$ref": "#/$defs/BaseSlicerProps" }],
      "type": "object",
      "required": ["type", "field"],
      "properties": {
        "type": { "const": "list" },
        "searchThreshold": { "type": "number", "minimum": 0 },
        "selectAll": { "type": "boolean" }
      }
    },
    "RangeSlicerSpec": {
      "allOf": [{ "$ref": "#/$defs/BaseSlicerProps" }],
      "type": "object",
      "required": ["type", "field"],
      "properties": {
        "type": { "const": "range" },
        "min": { "type": "number" },
        "max": { "type": "number" },
        "step": { "type": "number" },
        "format": { "type": "string" }
      }
    },
    "DateRangeSlicerSpec": {
      "allOf": [{ "$ref": "#/$defs/BaseSlicerProps" }],
      "type": "object",
      "required": ["type", "field"],
      "properties": {
        "type": { "const": "dateRange" },
        "presets": { "type": "boolean" },
        "format": { "type": "string" }
      }
    },
    "ChartOrSlicerSpec": {
      "oneOf": [
        { "$ref": "#/$defs/LineSpec" },
        { "$ref": "#/$defs/AreaSpec" },
        { "$ref": "#/$defs/BarSpec" },
        { "$ref": "#/$defs/ScatterSpec" },
        { "$ref": "#/$defs/ComboSpec" },
        { "$ref": "#/$defs/HistogramSpec" },
        { "$ref": "#/$defs/PieSpec" },
        { "$ref": "#/$defs/FunnelSpec" },
        { "$ref": "#/$defs/HeatmapSpec" },
        { "$ref": "#/$defs/KpiSpec" },
        { "$ref": "#/$defs/TreemapSpec" },
        { "$ref": "#/$defs/GaugeSpec" },
        { "$ref": "#/$defs/BulletSpec" },
        { "$ref": "#/$defs/CalendarHeatmapSpec" },
        { "$ref": "#/$defs/WaterfallSpec" },
        { "$ref": "#/$defs/SlopeSpec" },
        { "$ref": "#/$defs/DumbbellSpec" },
        { "$ref": "#/$defs/TableSpec" },
        { "$ref": "#/$defs/MatrixSpec" },
        { "$ref": "#/$defs/BoxSpec" },
        { "$ref": "#/$defs/SankeySpec" },
        { "$ref": "#/$defs/ChoroplethSpec" },
        { "$ref": "#/$defs/DropdownSlicerSpec" },
        { "$ref": "#/$defs/SearchSlicerSpec" },
        { "$ref": "#/$defs/ListSlicerSpec" },
        { "$ref": "#/$defs/RangeSlicerSpec" },
        { "$ref": "#/$defs/DateRangeSlicerSpec" }
      ]
    },
    "DashboardLayout": {
      "type": "object",
      "properties": {
        "cols": { "type": "number", "minimum": 1 },
        "rowHeight": { "type": "number", "minimum": 1 },
        "gap": { "type": "number", "minimum": 0 },
        "breakpoints": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["maxWidth", "cols"],
            "properties": {
              "maxWidth": { "type": "number", "minimum": 1 },
              "cols": { "type": "number", "minimum": 1 }
            },
            "additionalProperties": false
          }
        },
        "navigators": { "enum": ["top", "inline"] },
        "sections": { "type": "array", "items": { "$ref": "#/$defs/DashboardSection" } },
        "preset": { "type": "string", "enum": ["auto", "kpi-first", "sidebar"] },
        "maxWidth": { "type": "number", "minimum": 0 },
        "density": { "type": "string", "enum": ["compact", "standard", "comfortable"] },
        "padding": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "DashboardSection": {
      "type": "object",
      "required": ["views"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "views": { "type": "array", "items": { "type": "string" } },
        "cols": { "type": "number", "minimum": 1 },
        "rowHeight": { "type": "number", "minimum": 1 },
        "background": { "type": "string" },
        "collapsed": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "DashboardResponsiveSpan": {
      "type": "object",
      "required": ["maxWidth"],
      "properties": {
        "maxWidth": { "type": "number", "minimum": 1 },
        "w": { "type": "number", "minimum": 1 },
        "h": { "type": "number", "minimum": 1 },
        "hidden": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "DashboardView": {
      "type": "object",
      "required": ["id", "spec"],
      "properties": {
        "id": { "type": "string" },
        "spec": { "$ref": "#/$defs/ChartOrSlicerSpec" },
        "x": { "type": "number", "minimum": 1 },
        "y": { "type": "number", "minimum": 1 },
        "w": { "type": "number", "minimum": 1 },
        "h": { "type": "number", "minimum": 1 },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "frame": { "type": "boolean" },
        "background": { "type": "string" },
        "accent": { "type": "string" },
        "padding": { "type": "string", "enum": ["none", "standard"] },
        "responsive": { "type": "array", "items": { "$ref": "#/$defs/DashboardResponsiveSpan" } }
      },
      "additionalProperties": false
    },
    "InteractionLink": {
      "type": "object",
      "required": ["source", "target"],
      "properties": {
        "source": { "type": "string" },
        "target": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } }
          ]
        },
        "as": { "type": "string", "enum": ["highlight", "filter", "none"] },
        "fields": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "DashboardSpec": {
      "type": "object",
      "required": ["type", "views"],
      "properties": {
        "type": { "const": "dashboard" },
        "data": { "type": "array", "items": { "$ref": "#/$defs/Datum" } },
        "theme": { "$ref": "#/$defs/ThemeInput" },
        "title": { "$ref": "#/$defs/TitleConfig" },
        "subtitle": { "type": "string" },
