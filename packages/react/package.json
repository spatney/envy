{
  "name": "@graphein/react",
  "version": "0.7.1",
  "type": "module",
  "description": "Graphein React wrapper — declarative <Chart spec={...} /> for the Graphein visualization engine.",
  "license": "MIT",
  "author": "Sachin Patney <sachin.patney@gmail.com>",
  "homepage": "https://github.com/spatney/graphein/tree/main/packages/react#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spatney/graphein.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/spatney/graphein/issues"
  },
  "keywords": [
    "react",
    "visualization",
    "charts",
    "dataviz",
    "graphein",
    "agent",
    "declarative"
  ],
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepack": "tsup"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "dependencies": {
    "graphein": "^0.7.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^25.0.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
